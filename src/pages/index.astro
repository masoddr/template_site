---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Footer from '../components/Footer.astro';
import Services from '../components/Services.astro';
import Testimonials from '../components/Testimonials.astro';
import Map from '../components/Map.astro';
import BusinessHours from '../components/BusinessHours.astro';
import Pricing from '../components/Pricing.astro';
import Gallery from '../components/Gallery.astro';
import Story from '../components/Story.astro';
import { defaultConfig } from '../config/site';

const galleryItems = [
	{
		image: "/images/gallery/bike-1.jpg",
		title: "Peugeot PX-10",
		description: "Restauration complète d'un classique des années 70",
		year: "1972"
	},
	{
		image: "/images/gallery/bike-2.jpg",
		title: "Raleigh Professional",
		description: "Vélo de course sur mesure",
		year: "2023"
	},
	{
		image: "/images/gallery/bike-3.jpg",
		title: "Gitane Tour de France",
		description: "Restauration premium avec finitions artisanales",
		year: "1968"
	}
];
---

<BaseLayout>
	<Header />
	<main class="bg-[#F5F5F0]">
		<Hero 
			title="Artisanat de vélos vintage sur mesure"
			description="Transformez votre passion en réalité avec nos créations uniques"
			ctaText="Construire mon vélo"
			ctaLink="/contact"
			imageSrc="/images/hero-vintage-bike.jpg"
		/>
		<Story />
		<Services config={defaultConfig} />
		<Gallery items={galleryItems} />
		<Testimonials config={defaultConfig} />
		<Pricing
			title={defaultConfig.pricing.title}
			description={defaultConfig.pricing.description}
			items={defaultConfig.pricing.items}
		/>
		<Map 
			title={defaultConfig.location.title}
			address={defaultConfig.location.address}
			mapUrl={defaultConfig.location.mapUrl}
		/>
		<BusinessHours
			title={defaultConfig.businessHours.title}
			hours={defaultConfig.businessHours.hours}
			timezone={defaultConfig.businessHours.timezone}
		/>
	</main>
	<Footer />
</BaseLayout>

<style>
	:global(body) {
		@apply bg-[#F5F5F0] text-[#2C3E50];
	}
	
	:global(h1, h2, h3, h4, h5, h6) {
		@apply font-serif;
	}
	
	:global(p) {
		@apply font-sans;
	}
</style>
